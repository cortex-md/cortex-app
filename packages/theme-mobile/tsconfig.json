{
	"compilerOptions": {
		"composite": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist",
		"baseUrl": "."
	},
	"include": ["src"]
}
