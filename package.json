{
	"name": "cortex",
	"private": true,
	"packageManager": "bun@1.3.3",
	"workspaces": [
		"apps/*",
		"packages/*",
		"plugins/*",
		"tools/*"
	],
	"scripts": {
		"build": "bun run build:desktop",
		"build:desktop": "bun run --cwd apps/desktop build",
		"build:web": "bun run --cwd apps/web build",
		"dev:desktop": "bun run --cwd apps/desktop tauri dev",
		"dev:mobile": "bun run --cwd apps/mobile start",
		"dev:web": "bun run --cwd apps/web dev",
		"tauri": "bun run --cwd apps/desktop tauri",
		"lint": "bun run lint:desktop",
		"lint:desktop": "bun scripts/run-biome-target.mjs desktop lint",
		"lint:desktop:fix": "bun scripts/run-biome-target.mjs desktop lint --fix",
		"lint:mobile": "bun run --cwd apps/mobile lint",
		"lint:web": "bun run --cwd apps/web lint",
		"lint:all": "biome lint .",
		"lint:fix": "bun run lint:desktop:fix",
		"format": "bun run format:desktop",
		"format:desktop": "bun scripts/run-biome-target.mjs desktop format",
		"format:desktop:fix": "bun scripts/run-biome-target.mjs desktop format --write",
		"format:web": "bun run --cwd apps/web format",
		"format:all": "biome format .",
		"format:fix": "bun run format:desktop:fix",
		"check": "bun run check:desktop",
		"check:desktop": "bun scripts/run-biome-target.mjs desktop check",
		"check:desktop:fix": "bun scripts/run-biome-target.mjs desktop check --write",
		"check:mobile": "bun run --cwd apps/mobile check",
		"check:web": "bun run --cwd apps/web check",
		"check:web:fix": "bun run --cwd apps/web check:fix",
		"check:all": "biome check .",
		"check:all:fix": "biome check --write .",
		"check:fix": "bun run check:desktop:fix",
		"check:boundaries": "bun run scripts/check-workspace-boundaries.ts",
		"typecheck": "bun run typecheck:desktop",
		"typecheck:desktop": "tsc -b tsconfig.desktop.json",
		"typecheck:mobile": "bun run --cwd apps/mobile typecheck",
		"typecheck:web": "bun run --cwd apps/web typecheck",
		"typecheck:all": "tsc -b",
		"test": "bun run test:desktop",
		"test:desktop": "bun run test:desktop:frontend && bun run test:rust",
		"test:desktop:frontend": "bun scripts/run-vitest-target.mjs desktop",
		"test:mobile": "bun run --cwd apps/mobile test",
		"test:web": "bun run --cwd apps/web test",
		"test:frontend": "bun run test:desktop:frontend",
		"test:frontend:all": "bun run test:desktop:frontend && bun run --cwd packages/theme-mobile vitest run && bun run --cwd apps/web vitest run",
		"test:all": "bun run test:desktop && bun run test:web && bun run test:mobile",
		"test:rust": "cargo test --workspace --manifest-path apps/desktop/src-tauri/Cargo.toml",
		"test:watch": "vitest",
		"mobile:start": "bun run --cwd apps/mobile start",
		"mobile:ios": "bun run --cwd apps/mobile ios",
		"mobile:android": "bun run --cwd apps/mobile android",
		"mobile:web": "bun run --cwd apps/mobile web",
		"benchmark:bookmarks": "bun run --cwd tools/benchmarks bench:bookmarks",
		"benchmark:editor": "bun run --cwd tools/benchmarks bench:live-preview",
		"benchmark:file-explorer": "bun run --cwd tools/benchmarks bench:file-tree",
		"benchmark:note-open": "bun run --cwd tools/benchmarks bench:note-open",
		"benchmark:large-vault": "bun run --cwd apps/desktop bench:large-vault",
		"benchmark:large-vault:smoke": "bun run --cwd apps/desktop bench:large-vault:smoke",
		"test:coverage": "bun run test:coverage:desktop",
		"test:coverage:desktop": "bun run --cwd packages/core vitest run --coverage && bun run --cwd packages/settings vitest run --coverage && bun run --cwd packages/editor vitest run --coverage && bun run --cwd packages/renderer vitest run --coverage && bun run --cwd packages/plugin-host-core vitest run --coverage && bun run --cwd packages/plugin-host-web vitest run --coverage && bun run --cwd packages/marketplace vitest run --coverage && bun run --cwd apps/desktop vitest run --coverage",
		"doctor": "bun run doctor:desktop",
		"doctor:desktop": "npx react-doctor@latest apps/desktop --verbose --scope changed",
		"doctor:desktop:full": "npx react-doctor@latest apps/desktop --verbose",
		"doctor:mobile": "bun run --cwd apps/mobile doctor",
		"doctor:mobile:full": "bun run --cwd apps/mobile doctor:full"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitest/coverage-v8": "^4.1.9",
		"jsdom": "^29.0.1",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"typescript": "~5.8.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@testing-library/dom": "^10.4.1"
	},
	"overrides": {
		"undici": "7.28.0"
	}
}
